{
  "manifest_version": 3,
  "name": "BulletChat",
  "version": "1.0.0",
  "description": "AI Prompt Shortcuts for LLMs，在 ChatGPT、Gemini 等聊天页面输入框旁插入快捷 prompt 按钮",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*",
        "https://doubao.com/*",
        "https://*.doubao.com/*",
        "https://qianwen.com/*",
        "https://*.qianwen.com/*",
        "https://tongyi.com/*",
        "https://*.tongyi.com/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*"
      ],
      "js": ["content/index.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
